---
interface Props {
    name: string;
    class?: string;
}

const { name, class: className = '' } = Astro.props;
---

<div class={`bg-surface/70 border border-line rounded-2xl p-6 ${className}`}>
    <h3 class="text-lg font-semibold text-zinc-300 mb-4">{name}</h3>
    <div class="flex flex-wrap gap-3">
        <slot />
    </div>
</div>
