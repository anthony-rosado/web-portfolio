---
import { Image } from 'astro:assets';
import photo from '../assets/images/profile-photo.png';
import locationIcon from '../assets/icons/location.svg';
import { accounts, cvUrl } from '../data/site';

const me = {
    photo: photo,
    name: 'Anthony Rosado',
    occupation: 'Desarrollador de software',
    location: 'Lima, Perú',
};
---

<section class="py-10 mx-10 smd:py-6">
    <div class="items-center md:space-x-4 text-wrap md:flex">
        <div>
            <Image
                src={me.photo}
                alt="Anthony Rosado"
                loading="eager"
                class="size-36 rounded-full mx-auto"
            />
        </div>
        <div class="grow text-center md:text-left">
            <h1 class="text-3xl md:text-4xl font-bold text-amber-400">{me.name}</h1>
            <h2 class="text-lg md:text-xl text-gray-200">{me.occupation}</h2>
            <div class="flex items-center justify-center md:justify-start text-gray-400 gap-2 mt-1">
                <Image src={locationIcon} alt="" loading="eager" class="w-5 h-5" />
                <span class="text-sm">{me.location}</span>
            </div>
            <a
                href={cvUrl}
                download
                class="inline-flex items-center gap-2 mt-4 px-4 py-2 bg-amber-400 text-slate-900 font-medium
                rounded-full shadow-sm hover:bg-amber-300 hover:scale-105 transition-all duration-200"
            >
                Descargar CV
            </a>
        </div>
        <div class="flex flex-row justify-center gap-4 mt-4 md:mt-1 sm:mt-0">
            {
                accounts.map((account) => (
                    <a
                        href={account.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        title={account.platform}
                        aria-label={account.platform}
                        class="hover:scale-110 transition-transform hover:brightness-125"
                    >
                        <img src={account.icon} alt="" loading="eager" class="size-9" />
                    </a>
                ))
            }
        </div>
    </div>
</section>
