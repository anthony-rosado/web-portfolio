---
interface Props {
    name: string;
    icon: string;
}

const { name, icon } = Astro.props;
---

<figure
    class="flex items-center gap-3 bg-line/50 border border-line px-4 py-2 rounded-full
             shadow-sm hover:border-accent/50 hover:scale-105 transition-all duration-300 cursor-default"
>
    <img src={icon} alt={name} loading="lazy" class="w-6 h-6 md:w-7 md:h-7" />
    <figcaption class="text-sm text-zinc-200 md:text-base">{name}</figcaption>
</figure>
