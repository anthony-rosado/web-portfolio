---
import Section from './Section.astro';
import userIcon from '../assets/icons/user.svg';
import { contactEmail, accounts } from '../data/site';
---

<Section id="contact" title="Contacto" icon={userIcon}>
    <p class="text-sm sm:text-base text-pretty text-zinc-300">
        ¿Tienes un proyecto en mente o una oportunidad? Escríbeme y conversemos.
    </p>
    <div class="flex flex-wrap items-center gap-4">
        <a
            href={`mailto:${contactEmail}`}
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-canvas font-medium
            rounded-full shadow-sm hover:bg-accent-soft hover:scale-105 transition-all duration-200"
        >
            {contactEmail}
        </a>
        <div class="flex flex-row gap-3">
            {
                accounts.map((account) => (
                    <a
                        href={account.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        title={account.platform}
                        aria-label={account.platform}
                        class="hover:scale-110 transition-transform hover:brightness-125"
                    >
                        <img src={account.icon} alt="" loading="lazy" class="size-9" />
                    </a>
                ))
            }
        </div>
    </div>
</Section>
