---
import { Image } from 'astro:assets';
import Section from './Section.astro';
import experienceIcon from '../assets/icons/experience.svg';
import companyIcon from '../assets/icons/company.svg';

interface Experience {
    position: string;
    company: string;
    companyLogo: string;
    startDate: string;
    endDate: string;
    location: string;
    modality: string;
    description: Array<string>;
}

const experiences: Experience[] = [
    {
        position: 'Desarrollador Backend',
        company: 'ID B.I.',
        companyLogo: '/images/logos/idbi.jpeg',
        startDate: 'Jul 2020',
        endDate: 'Jun 2026',
        location: 'Lima, Perú',
        modality: 'Remoto',
        description: [
            'Reduje en un 40% el tiempo de respuesta promedio de las APIs optimizando código PHP y consultas SQL, e implementando caching con Redis en más de 30 endpoints críticos.',
            'Integré 5 ERPs y 3 pasarelas de pago mediante APIs REST en Laravel, habilitando la sincronización de pedidos y pagos en tiempo real.',
            'Reduje en un 15% los errores en producción al establecer un proceso de code review para un equipo de 4 desarrolladores.',
            'Diseñé y optimicé esquemas de bases de datos relacionales, mejorando el rendimiento y la estructura de los datos.',
        ],
    },
    {
        position: 'Desarrollador Fullstack',
        company: 'Peru Apps',
        companyLogo: '/images/logos/peru-apps.jpeg',
        startDate: 'Ene 2020',
        endDate: 'Jul 2020',
        location: 'Lima, Perú',
        modality: 'Presencial',
        description: [
            'Desarrollé e implementé 3 aplicaciones web y móviles para distintas empresas cliente bajo un modelo de factoría de software.',
            'Cubrí principalmente el desarrollo backend de cada proyecto, colaborando en equipos multidisciplinarios de 4 personas.',
        ],
    },
    {
        position: 'Desarrollador Web',
        company: 'San Fernando',
        companyLogo: '/images/logos/san-fernando.jpeg',
        startDate: 'Jun 2019',
        endDate: 'Ago 2019',
        location: 'Huaral, Perú',
        modality: 'Presencial',
        description: [
            'Realicé mi práctica profesional participando en el desarrollo y las pruebas funcionales de un sistema de monitoreo de líneas de producción.',
            'Validé el registro de indicadores operativos en tiempo real, apoyando la detección temprana de incidencias en planta.',
        ],
    },
];
---

<Section id="experience" title="Experiencia" icon={experienceIcon}>
    <div class="relative ml-2 space-y-8 border-l border-line pl-6 md:pl-8">
        {
            experiences.map((exp) => (
                <div class="relative">
                    <span class="absolute top-2 -left-6 size-3 -translate-x-1/2 rounded-full bg-accent ring-4 ring-canvas md:-left-8" />
                    <div class="bg-surface/70 backdrop-blur-sm p-6 rounded-2xl shadow-lg border border-line transition-shadow hover:shadow-xl">
                        <div class="flex items-center gap-4 mb-4">
                            <img
                                src={exp.companyLogo}
                                alt={exp.company}
                                loading="lazy"
                                class="size-16 rounded-xl object-contain bg-line p-1.5"
                            />
                            <div class="flex flex-col sm:flex-row sm:justify-between w-full">
                                <div>
                                    <h3 class="text-2xl font-semibold text-accent text-balance">
                                        {exp.position}
                                    </h3>
                                    <div class="flex items-center gap-2 text-zinc-400 text-sm">
                                        <Image src={companyIcon} alt="" class="size-4" />
                                        <span>{exp.company}</span>
                                    </div>
                                </div>
                                <div class="text-sm text-zinc-300 mt-2 sm:mt-0 sm:text-right">
                                    <p>
                                        {exp.startDate} – {exp.endDate}
                                    </p>
                                    <p class="text-zinc-400">
                                        {exp.location} –{' '}
                                        <span class="text-accent">{exp.modality}</span>
                                    </p>
                                </div>
                            </div>
                        </div>

                        <ul class="text-sm list-disc list-inside space-y-2 text-zinc-300 pl-2 md:pl-6 md:text-base">
                            {exp.description.map((item) => (
                                <li>{item}</li>
                            ))}
                        </ul>
                    </div>
                </div>
            ))
        }
    </div>
</Section>
