---
import Section from './Section.astro';
import projectIcon from '../assets/icons/project.svg';

interface Technology {
    name: string;
    icon: string;
}

interface Link {
    name: string;
    url: string;
    icon: string;
}

interface Project {
    name: string;
    links: Link[];
    description: string;
    technologies: Technology[];
}

const projects: Project[] = [
    {
        name: 'Portafolio web',
        links: [{ name: 'Web', url: '/', icon: '/icons/internet.svg' }],
        description:
            'Sitio personal construido con Astro y Tailwind CSS. Optimizado para rendimiento con ' +
            'imágenes en WebP, accesible y con SEO cuidado mediante metadatos Open Graph y sitemap.',
        technologies: [
            { name: 'HTML', icon: '/icons/skills/html5.svg' },
            { name: 'CSS', icon: '/icons/skills/css3.svg' },
            { name: 'Javascript', icon: '/icons/skills/javascript.svg' },
            { name: 'Astro', icon: '/icons/skills/astro.svg' },
            { name: 'Tailwind', icon: '/icons/skills/tailwind.svg' },
            { name: 'Git', icon: '/icons/skills/git.svg' },
        ],
    },
    {
        name: 'Algolia Explorer',
        links: [
            {
                name: 'GitHub',
                url: 'https://github.com/anthony-rosado/algolia-explorer',
                icon: '/icons/github.svg',
            },
        ],
        description:
            'API en Laravel 11 que integra el cliente oficial de Algolia para indexar y buscar ' +
            'productos y categorías de forma eficiente, con soporte para múltiples aplicaciones de ' +
            'Algolia. Incluye pruebas con PHPUnit y análisis estático del código.',
        technologies: [
            { name: 'PHP', icon: '/icons/skills/php.svg' },
            { name: 'Laravel', icon: '/icons/skills/laravel.svg' },
            { name: 'MySQL', icon: '/icons/skills/mysql.svg' },
            { name: 'JSON', icon: '/icons/skills/json.svg' },
            { name: 'Git', icon: '/icons/skills/git.svg' },
            { name: 'Docker', icon: '/icons/skills/docker.svg' },
            { name: 'Algolia', icon: '/icons/skills/algolia.svg' },
        ],
    },
    {
        name: 'XML Invoice Recorder',
        links: [
            {
                name: 'GitHub',
                url: 'https://github.com/anthony-rosado/xml-invoice-recorder',
                icon: '/icons/github.svg',
            },
        ],
        description:
            'API REST en Laravel para gestionar facturas electrónicas en XML: autenticación OAuth2 ' +
            'con Passport, carga y eliminación de archivos, listados paginados con detalle y ' +
            'agregación de montos por moneda. Contenerizada con Docker (Sail) y probada con PHPUnit.',
        technologies: [
            { name: 'PHP', icon: '/icons/skills/php.svg' },
            { name: 'Laravel', icon: '/icons/skills/laravel.svg' },
            { name: 'MySQL', icon: '/icons/skills/mysql.svg' },
            { name: 'JSON', icon: '/icons/skills/json.svg' },
            { name: 'XML', icon: '/icons/skills/xml.svg' },
            { name: 'Git', icon: '/icons/skills/git.svg' },
            { name: 'Docker', icon: '/icons/skills/docker.svg' },
        ],
    },
    {
        name: 'Notes Challenge',
        links: [
            {
                name: 'GitHub',
                url: 'https://github.com/anthony-rosado/notes-challenge',
                icon: '/icons/github.svg',
            },
        ],
        description:
            'API REST en Laravel para gestionar notas de usuarios, con autenticación OAuth2 ' +
            '(Passport) y notificaciones por correo procesadas de forma asíncrona mediante colas. ' +
            'Cuenta con una suite de pruebas automatizadas y colección de Postman.',
        technologies: [
            { name: 'PHP', icon: '/icons/skills/php.svg' },
            { name: 'Laravel', icon: '/icons/skills/laravel.svg' },
            { name: 'MySQL', icon: '/icons/skills/mysql.svg' },
            { name: 'JSON', icon: '/icons/skills/json.svg' },
            { name: 'Git', icon: '/icons/skills/git.svg' },
        ],
    },
];
---

<Section id="projects" title="Proyectos" icon={projectIcon}>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-y-6 sm:gap-x-4 sm:gap-y-5">
        {
            projects.map((project) => (
                <div
                    class="flex flex-col bg-surface/70 backdrop-blur-md p-6 rounded-2xl
    shadow-lg border border-line hover:border-accent/40 hover:shadow-2xl transition-all duration-300"
                >
                    <div class="flex flex-col justify-between">
                        <div class="flex flex-col">
                            <h3 class="text-2xl font-bold text-accent text-center">
                                {project.name}
                            </h3>
                            <div class="flex gap-2 mt-2 justify-center">
                                {project.links.map((link) => (
                                    <a
                                        href={link.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="hover:scale-110 transition-transform hover:brightness-125"
                                    >
                                        <img
                                            class="w-7 h-7"
                                            loading="lazy"
                                            src={link.icon}
                                            alt={link.name}
                                        />
                                    </a>
                                ))}
                            </div>
                        </div>
                        <p class="text-sm text-zinc-300 mt-4 text-pretty sm:text-base">
                            {project.description}
                        </p>
                        <div class="flex flex-wrap justify-center gap-2 mt-4">
                            {project.technologies.map((tech) => (
                                <figure
                                    class="flex items-center gap-2 bg-line/60 px-3 py-1 rounded-full text-sm
                        text-zinc-200 cursor-default"
                                >
                                    <img
                                        src={tech.icon}
                                        alt={tech.name}
                                        loading="lazy"
                                        class="w-5 h-5"
                                    />
                                    <figcaption>{tech.name}</figcaption>
                                </figure>
                            ))}
                        </div>
                    </div>
                </div>
            ))
        }
    </div>
</Section>
