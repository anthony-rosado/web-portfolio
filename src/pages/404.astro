---
import Layout from '../layouts/Layout.astro';
---

<Layout
    title="404 — Página no encontrada | Anthony Rosado"
    description="La página que buscas no existe."
>
    <section class="flex flex-col items-center justify-center text-center py-24 gap-4">
        <p class="text-7xl font-bold text-accent">404</p>
        <h1 class="text-2xl md:text-3xl font-semibold">Página no encontrada</h1>
        <p class="text-zinc-300 max-w-md text-pretty">
            Lo siento, la página que buscas no existe o fue movida.
        </p>
        <a
            href="/"
            class="inline-flex items-center gap-2 mt-2 px-5 py-2.5 bg-accent text-canvas font-medium
            rounded-full shadow-sm hover:bg-accent-soft hover:scale-105 transition-all duration-200"
        >
            Volver al inicio
        </a>
    </section>
</Layout>
